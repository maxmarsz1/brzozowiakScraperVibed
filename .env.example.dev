# --- Django Settings ---
DJANGO_DEBUG="True"
DJANGO_SECRET_KEY="django-insecure-dev-key-replace-me-in-prod"
DJANGO_ALLOWED_HOSTS="localhost 127.0.0.1 backend"

# --- Telegram Settings ---
# Get your token from @BotFather
TELEGRAM_BOT_TOKEN=""
# Get your chat ID from @userinfobot or by sending a message to your bot and checking https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_CHAT_ID=""

# --- Ports ---
BACKEND_PORT="8000"
FRONTEND_PORT="3000"

# --- Frontend Settings ---
VITE_API_URL="http://localhost:8000"

# --- Development Overrides ---
BACKEND_COMMAND="python manage.py runserver 0.0.0.0:8000"
