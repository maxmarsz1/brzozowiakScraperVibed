# --- Django Settings ---
DJANGO_DEBUG="False"
# Generate a secure key: python -c 'import secrets; print(secrets.token_urlsafe(50))'
DJANGO_SECRET_KEY=""
DJANGO_ALLOWED_HOSTS="your-domain.com"

# --- Telegram Settings ---
# Get your token from @BotFather
TELEGRAM_BOT_TOKEN=""
# Get your chat ID from @userinfobot
TELEGRAM_CHAT_ID=""

# --- Ports ---
BACKEND_PORT="8000"
FRONTEND_PORT="3000"

# --- Frontend Settings ---
FRONTEND_MODE="django"

# --- Backend Command ---
BACKEND_COMMAND="gunicorn core.wsgi:application --bind 0.0.0.0:8000 --workers 3"
